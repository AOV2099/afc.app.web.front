# API base URL for frontend services
VITE_API_BASE_URL=
# Optional fallback port when VITE_API_BASE_URL is empty (default: 3004)
VITE_API_PORT=3004

# Option A: provide absolute paths available inside container/host
VITE_DEV_HTTPS_KEY_PATH=
VITE_DEV_HTTPS_CERT_PATH=

# Option B: provide PEM content directly (can include \n escaped newlines)
VITE_DEV_HTTPS_KEY=
VITE_DEV_HTTPS_CERT=

# Option C: provide base64 PEM content
VITE_DEV_HTTPS_KEY_BASE64=
VITE_DEV_HTTPS_CERT_BASE64=
